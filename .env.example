# TinaCMS Configuration (required)
NEXT_PUBLIC_TINA_CLIENT_ID=your_tina_client_id_here
TINA_TOKEN=your_tina_token_here

# Optional: local GitHub PAT for legacy/local git workflows
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_pat_here

# AWS Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=us-east-1
AWS_S3_BUCKET=auditik-website-prod
CLOUDFRONT_DISTRIBUTION_ID=your_cloudfront_distribution_id_here

# Google Analytics
NEXT_PUBLIC_GA_ID=your_google_analytics_id_here

# Meta Pixel (required for Meta Ads tracking)
NEXT_PUBLIC_META_PIXEL_ID=your_meta_pixel_id_here

# Google Ads account ID (required for Google Ads conversion tracking)
# Example: AW-123456789
NEXT_PUBLIC_GOOGLE_ADS_ID=your_google_ads_id_here

# Google Ads conversion labels (one label per conversion action)
# Replace placeholders with real labels from Google Ads -> Goals -> Conversions
NEXT_PUBLIC_GOOGLE_ADS_LABEL_CONTACT=your_google_ads_label_contact_here
NEXT_PUBLIC_GOOGLE_ADS_LABEL_APPOINTMENT=your_google_ads_label_appointment_here
NEXT_PUBLIC_GOOGLE_ADS_LABEL_WHATSAPP=your_google_ads_label_whatsapp_here
NEXT_PUBLIC_GOOGLE_ADS_LABEL_PHONE=your_google_ads_label_phone_here

# WhatsApp lead integration proxy (required in static hosting)
# This must be a secure backend endpoint that injects X-Api-Key server-side.
NEXT_PUBLIC_LEAD_PROXY_URL=https://your-proxy-domain.com/integrations/leads
# Integration name expected by add_new_lead_proxy payload.
NEXT_PUBLIC_LEAD_INTEGRATION_NAME=planilha-funil

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://auditik.com.br
NEXT_PUBLIC_SITE_NAME=Auditik

# API Keys (for future integrations)
NEXT_PUBLIC_API_URL=https://api.auditik.com.br
