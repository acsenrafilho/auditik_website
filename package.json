{
  "name": "auditik-website",
  "version": "1.0.0",
  "description": "Auditik - Philips HearLink Hearing Aid Provider Website",
  "private": true,
  "scripts": {
    "dev": "TINA_PUBLIC_IS_LOCAL=true tinacms dev -c \"next dev\"",
    "build": "tinacms build && npm run tina:build && node scripts/generate-sitemap.mjs && next build",
    "start": "next start",
    "lint": "next lint",
    "export": "next build",
    "tina:dev": "npx -y @tinacms/cli@1.6.7 dev --local --skip-cloud-checks -c \"npm run dev\"",
    "tina:build": "dotenv -e .env.local -- npx -y @tinacms/cli@1.6.7 build --skip-cloud-checks"
  },
  "dependencies": {
    "@udecode/plate": "^36.5.9",
    "@udecode/plate-common": "^36.0.0",
    "axios": "^1.6.0",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.1.1",
    "next": "14.2.35",
    "next-seo": "^6.1.0",
    "next-tinacms-github": "^1.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tinacms": "^1.5.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.0",
    "@tinacms/cli": "^1.6.7",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.19.39",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.55.0",
    "eslint-config-next": "14.2.35",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.3.0"
  }
}
